// This is your Prisma schema file, learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions? Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// "build": "prisma generate && next build" --> This ensueres that the Prisma Client is generated before building the Next.js app or deploying it to production.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql" 
}

enum InvoiceStatus {
  PAID
  DRAFT
  VOID
}

model User {
  id Int @id @default(autoincrement())
  clerkId String @unique
  name String?
  email String?

  clients Client[]
  invoices Invoice[]

  createdAt DateTime @default(now())
}

model Client{
  id Int @id @default(autoincrement())
  name String?
  email String?
  country String?
  isArchived Boolean   @default(false)
  
  userId Int
  user User @relation(fields:[userId], references: [id])

  invoices Invoice[]
}

model Invoice {
  id Int @id @default(autoincrement())
  invoiceNumber String

  issueDate DateTime @default(now())
  dueDate DateTime
  // Taken from User or edited by User
  fromName      String?  
  fromEmail     String?  

  // Taken from Client
  clientName    String?
  clientEmail   String?
  clientRegion   String?

  status String 
  currency String @default("USD")
  subtotal Float
  taxLabel String @default("Tax")
  taxRate Float   @default(0)
  discountAmount Float @default(0)
  amountPaid Float @default(0)
  totalAmount Float

  isArchived  Boolean  @default(false)
  notes String?

  userId Int
  user User @relation(fields: [userId], references: [id])

  clientId Int?
  client Client? @relation(fields:[clientId], references: [id])

  items InvoiceItem[]

  createdAt DateTime @default(now())
}

model InvoiceItem {
  id Int @id @default(autoincrement())
  type        String
  description String
  quantity Int
  price Float
  
  invoiceId Int
  invoice Invoice @relation(fields: [invoiceId], references: [id])
}